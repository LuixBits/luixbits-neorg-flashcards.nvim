Output docs/demo/review.gif

Set Width 1100
Set Height 720
Set FontSize 22
Set Framerate 18
Set PlaybackSpeed 0.9
Set FontFamily "Noto Sans Mono CJK JP"
Set Theme "Catppuccin Mocha"

Type "scripts/demo-session.sh"
Enter
Sleep 900ms

Type ":NeorgFlashcardReview"
Enter
Sleep 1200ms

Space
Sleep 1500ms

Type "2"
Sleep 900ms

Space
Sleep 1400ms

Type "1"
Sleep 900ms

Type ":NeorgFlashcardReviewScore bad"
Enter
Sleep 1400ms

Space
Sleep 1300ms

Type "q"
Sleep 500ms

Type ":qa!"
Enter

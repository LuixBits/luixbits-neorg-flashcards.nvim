{
  "name": "luixbits-neorg-flashcards-video",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "check": "tsc --noEmit",
    "compositions": "remotion compositions src/index.ts",
    "render": "remotion render src/index.ts FlashcardsExplainer out/flashcards-explainer.mp4 --codec=h264 --overwrite",
    "still": "remotion still src/index.ts FlashcardsExplainer out/flashcards-explainer.png --frame=1320 --overwrite",
    "studio": "remotion studio src/index.ts"
  },
  "dependencies": {
    "@remotion/cli": "4.0.494",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.494"
  },
  "devDependencies": {
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "typescript": "5.9.3"
  }
}
